# ==========================================
# SECRETOS Y CONFIGURACIÓN SENSIBLE
# ==========================================
.env
.env.*
!.env.example
!.env.sample

config.local.php
config/*.local.php
credentials.php
db.config.php
secrets/
.secrets/
credentials/

# Llaves y certificados
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.asc
*.gpg
id_rsa*
id_ed25519*
*_rsa
*_ed25519

# Cloud
.azure/
*.publishsettings
*.pubxml
*.pubxml.user
cloudflared.yml
.cloudflared/

# ==========================================
# BASE DE DATOS
# ==========================================
*.sql
*.sql.gz
*.dump
*.bak
*.backup
*.sqlite
*.sqlite3
*.db
backup/
backups/
dumps/
# Excepciones: DDL de migraciones y schema base
!sql/migracion_*.sql
!sql/schema.sql
!sql/*.example.sql
!database/migrations/**/*.sql

